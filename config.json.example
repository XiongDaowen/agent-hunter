{
  "name": "agent-hunter",
  "version": "1.1.0",
  "description": "全球 AI Agent 产品检索与追踪",
  "cache_dir": "cache",
  "agents_dir": "agents",
  "report_dir": "report",
  "report_file": "report/index.html",
  "meta_file": "cache/meta.json",
  "categories": ["IDE", "CLI", "TUI", "GUI", "Plugin", "SDK", "Other"],
  "update_interval_hours": 24,
  "search_sources": {
    "domestic": {
      "360_search": {
        "enabled": true,
        "description": "360搜索（免费，覆盖知乎/微信公众号/掘金等中文站点）"
      },
      "firecrawl": {
        "enabled": false,
        "sites": ["zhihu.com", "zhuanlan.zhihu.com", "juejin.cn", "blog.csdn.net", "oschina.net", "infoq.cn", "36kr.com", "sspai.com"]
      }
    },
    "overseas": {
      "duckduckgo": {
        "enabled": true,
        "description": "DuckDuckGo（免费，覆盖全球英文站点）"
      },
      "firecrawl": {
        "enabled": false,
        "sites": ["producthunt.com", "news.ycombinator.com", "techcrunch.com", "github.com", "medium.com", "dev.to"]
      }
    }
  },
  "llm": {
    "base_url": "https://api.example.com/anthropic",
    "api_key": "your-api-key-here",
    "model": "MiniMax-M2.7"
  }
}
